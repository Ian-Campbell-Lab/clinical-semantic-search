# clinical-semantic-search configuration
# Copy this file to .env and fill in your institution's values.

# ── Vector Search ────────────────────────────────────────────────────
# GCP project that hosts the Vertex AI vector search index
VECTOR_SEARCH_PROJECT=your-gcp-project-id

# Cloud region for Vertex AI (e.g. us-east4, us-central1)
CLOUD_REGION=us-east4

# Full resource name of the Vertex AI index endpoint
# Format: projects/<number>/locations/<region>/indexEndpoints/<id>
INDEX_ENDPOINT_PATH=projects/123456789/locations/us-east4/indexEndpoints/0000000000000000000

# Private Service Connect IP (leave empty if using public endpoint)
INDEX_PSC_IP=

# ID of the deployed index on the endpoint
DEPLOYED_INDEX_ID=your_deployed_index_id

# ── Metadata Store (BigTable) ───────────────────────────────────────
# GCP project that hosts the BigTable instance
METADATA_PROJECT=your-gcp-project-id

# BigTable instance name
BIGTABLE_INSTANCE=your-bigtable-instance

# BigTable table name (default: notes)
BIGTABLE_TABLE=notes

# ── Embedding Model ─────────────────────────────────────────────────
# Local path to the HuggingFace embedding model directory
EMBEDDING_MODEL_PATH=/path/to/your/embedding-model

# Instruction prefix for the embedding model (default shown below)
# EMBEDDING_INSTRUCTION=Given a medical query from a healthcare provider, retrieve relevant passages that answer the query

# ── Access Control ──────────────────────────────────────────────────
# GCP project for BigQuery-based access control (optional)
# ACCESS_CONTROL_PROJECT=your-project-id

# ── Timezone ────────────────────────────────────────────────────────
# Timezone for date filter conversion (default: America/New_York)
# TIMEZONE=America/New_York
